{
    "name": "dom-top-layer",
    "version": "0.1.0",
    "description": "A framework-agnostic TypeScript library for tracking browser top-layer state and subscribing to top-layer changes.",
    "keywords": [
        "top-layer",
        "browser",
        "dom",
        "dialog",
        "popover",
        "fullscreen",
        "typescript"
    ],
    "homepage": "https://github.com/marksmccann/dom-top-layer#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/marksmccann/dom-top-layer.git"
    },
    "bugs": {
        "url": "https://github.com/marksmccann/dom-top-layer/issues"
    },
    "license": "MIT",
    "author": "Mark McCann",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./*": null
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "llms.txt"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsup",
        "commit": "cz",
        "dev": "tsup --watch",
        "format": "prettier --write .",
        "lint": "eslint .",
        "prepublishOnly": "npm run build",
        "release": "release-it",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "node ./scripts/prepare.mjs"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "release-it": {
        "git": {
            "commitMessage": "chore(release): v${version}",
            "tagName": "v${version}",
            "requireCleanWorkingDir": true,
            "requireUpstream": true,
            "requireBranch": "main"
        },
        "npm": {
            "publish": true
        },
        "github": {
            "release": false
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "infile": "CHANGELOG.md",
                "header": "# Changelog",
                "preset": {
                    "name": "conventionalcommits"
                }
            }
        },
        "hooks": {
            "before:init": [
                "npm run lint",
                "npm run typecheck",
                "npm test"
            ]
        }
    },
    "lint-staged": {
        "*.{ts,js,cjs,mjs,md}": [
            "prettier --write"
        ],
        "*.{ts,js}": [
            "eslint --fix"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@eslint/js": "^10.0.1",
        "@release-it/conventional-changelog": "^10.0.5",
        "@types/node": "^24.10.1",
        "@vitest/coverage-v8": "^4.0.18",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "jsdom": "^27.2.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "release-it": "^19.2.4",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.3",
        "vitest": "^4.0.18"
    }
}
